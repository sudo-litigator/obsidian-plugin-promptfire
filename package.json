{
  "name": "promptfire",
  "version": "0.1.0",
  "description": "Obsidian plugin for copying structured vault context into AI models.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ai",
    "prompt"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "obsidian": "^1.12.3"
  }
}
